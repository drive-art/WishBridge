#!/data/data/com.termux/files/usr/bin/bash
CFG="$HOME/.wishbridge/config.json"
PORT=$(python3 -c "import json; print(json.load(open('$CFG')).get('llm_port',8080))" 2>/dev/null || echo 8080)
case "$1" in
  start)
    echo 'ūüöÄ –ó–į–Ņ—É—Ā–ļ WishBridge...'
    # –ó–į–Ņ—É—Ā–ļ–į–Ķ–ľ LLM –ł–∑ config.json
    MODEL=$(python3 -c "import json; print(json.load(open('$HOME/.wishbridge/config.json')).get('active_model',''))" 2>/dev/null)
    if ! curl -s http://127.0.0.1:$PORT/health > /dev/null 2>&1; then
      echo "ūüĆĶ Cactus: qwen3-0.6b-int4"
      nohup python3 ~/AI/cactus_bridge.py \
        >> ~/WishBridge/logs/llm.log 2>&1 &
      echo "LLM PID: $!"
      sleep 8
    else
      echo 'ūüĆĶ Cactus —É–∂–Ķ –∑–į–Ņ—É—Č–Ķ–Ĺ'
    fi
    nohup python3 ~/WishBridge/aios_agent.py > ~/WishBridge/logs/aios.log 2>&1 &
    echo "Atlas PID: $!"
    sleep 3 && tail -5 ~/WishBridge/logs/aios.log
    ;;
  stop)
    pkill -f "aios_agent.py" && echo "ūüõĎ Atlas –ĺ—Ā—ā–į–Ĺ–ĺ–≤–Ľ–Ķ–Ĺ" || echo "–Ĺ–Ķ –∑–į–Ņ—É—Č–Ķ–Ĺ"
    pkill -f "llama-server" 2>/dev/null || true
    pkill -f "cactus_bridge.py" && echo "ūüõĎ LLM –ĺ—Ā—ā–į–Ĺ–ĺ–≤–Ľ–Ķ–Ĺ" || true
    ;;
  status)
    echo "ūüďä AIOS WishBridge Status"
    curl -s "http://127.0.0.1:$PORT/health" > /dev/null && echo "LLM: ‚úÖ" || echo "LLM: ‚ĚĆ"
    echo "RAM: $(awk '/MemAvailable/ {print int($2/1024)}' /proc/meminfo)MB available"
    echo "Temp: $(($(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null || echo 0)/1000))¬įC"
    BAT=$(termux-battery-status 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(str(int(d['percentage']))+'% '+d['status'])" 2>/dev/null)
    echo "Bat: ${BAT:-–Ĺ–Ķ–ī–ĺ—Ā—ā—É–Ņ–Ĺ–ĺ}"
    pgrep -f "aios_agent.py" > /dev/null && echo "Atlas: ‚úÖ –∑–į–Ņ—É—Č–Ķ–Ĺ" || echo "Atlas: ‚ĚĆ –Ĺ–Ķ –∑–į–Ņ—É—Č–Ķ–Ĺ"
    ;;
  logs)
    tail -30 ~/WishBridge/logs/aios.log 2>/dev/null || echo "(–Ĺ–Ķ—ā –Ľ–ĺ–≥–ĺ–≤)"
    ;;
  thermal)
    for i in $(seq 0 5); do
      T=$(cat /sys/class/thermal/thermal_zone${i}/temp 2>/dev/null) && echo "zone${i}: $((T/1000))¬įC"
    done
    ;;
  model)
    case "$2" in
      light) M="smollm2-1.7b-q4.gguf" ;;
      work)  M="nanbeige4.1-3b-q4_k_m.gguf" ;;
      power) M="qwen3.5-4b-q4.gguf" ;;
      *) echo "wb model light|work|power"; exit 1 ;;
    esac
    echo "ūüĒĄ –ü–Ķ—Ä–Ķ–ļ–Ľ—é—á–į—é –Ĺ–į $M..."
    pkill -f "llama-server" || true
    sleep 2
    nohup ~/llama.cpp/build/bin/llama-server \
      --model ~/.wishbridge/models/$M \
      --host 127.0.0.1 --port $PORT \
      --threads 4 --ctx-size 512 -ngl 0 \
      --temp 0.7 --repeat-penalty 1.1 \
      >> ~/WishBridge/logs/llm.log 2>&1 &
    echo "LLM PID: $!"
    sleep 8 && curl -s http://127.0.0.1:$PORT/health
    ;;
  mem|memory)
    python3 ~/wb_memory.py show
    ;;
  ma|mem-add)
    shift
    python3 ~/wb_memory.py add "$*"
    ;;
  ses|session)
    cat ~/.wishbridge/session.md
    ;;
  ses-edit|se)
    nano ~/.wishbridge/session.md
    ;;
  ses-add|sa)
    echo "$(date '+%Y-%m-%d %H:%M') ‚ÄĒ $2" >> ~/.wishbridge/session.md
    echo "‚úÖ –ī–ĺ–Ī–į–≤–Ľ–Ķ–Ĺ–ĺ –≤ –Ņ–į–ľ—Ź—ā—Ć"
    ;;
  mon)
    tmux kill-session -t wbmon 2>/dev/null || true
    tmux new-session -s wbmon ~/scans/monitor.sh
    ;;
  mon-stop)
    tmux kill-session -t monitor 2>/dev/null && echo "Monitor –ĺ—Ā—ā–į–Ĺ–ĺ–≤–Ľ–Ķ–Ĺ" || echo "–Ĺ–Ķ –∑–į–Ņ—É—Č–Ķ–Ĺ"
    ;;
  sc)
    case "$2" in
      sys)  ~/scans/scan_system.sh ;;
      ag)   ~/scans/scan_agents.sh ;;
      mod)  ~/scans/scan_models.sh ;;
      proc) ~/scans/scan_processes.sh ;;
      dup)  ~/scans/scan_duplicates.sh ;;
      mg)   ~/scans/scan_morning.sh ;;
      doctor) ~/scans/doctor.sh ;;
      run) ~/scans/run_sandbox.sh ;;
      doc) ~/scans/doctor.sh ;;
      *)    echo "wb sc: sys | ag | mod | proc | dup" ;;
    esac
    ;;
  scan)
    ~/scans/full_scan.sh
    ;;
  doctor|doc)
    ~/scans/doctor.sh
    ;;
  run)
    ~/scans/run_sandbox.sh
    ;;
  monster)
    python3 ~/wb_monster_scan.py
    ;;
  dashboard)
    python3 ~/AI/wb_dashboard.py
    ;;
  cluster)
    echo "ūüĆź –ó–į–Ņ—É—Ā–ļ –ļ–Ľ–į—Ā—ā–Ķ—Ä–į..."
    python3 ~/AI/auto_discover.py
    pkill -f master_router.py 2>/dev/null
    nohup python3 ~/AI/master_router.py > ~/WishBridge/logs/router.log 2>&1 &
    echo "Router PID: $!"
    ;;
  *)
    echo ""
    echo "AIOS WishBridge | wb <–ļ–ĺ–ľ–į–Ĺ–ī–į>"
    echo "  start              ‚ÄĒ –∑–į–Ņ—É—Ā—ā–ł—ā—Ć Atlas"
    echo "  stop               ‚ÄĒ –ĺ—Ā—ā–į–Ĺ–ĺ–≤–ł—ā—Ć"
    echo "  status             ‚ÄĒ —Ā–ĺ—Ā—ā–ĺ—Ź–Ĺ–ł–Ķ"
    echo "  logs               ‚ÄĒ –Ľ–ĺ–≥–ł"
    echo "  thermal            ‚ÄĒ —ā–Ķ–ľ–Ņ–Ķ—Ä–į—ā—É—Ä–į"
    echo "  scan               ‚ÄĒ –ĺ–Ī–∑–ĺ—Ä"
    echo "  model light|work|power ‚ÄĒ –Ņ–Ķ—Ä–Ķ–ļ–Ľ—é—á–ł—ā—Ć –ľ–ĺ–ī–Ķ–Ľ—Ć"
    echo "  sc sys|ag|mod|proc|dup ‚ÄĒ —Ā–ļ–į–Ĺ—č —Ā–ł—Ā—ā–Ķ–ľ—č"
  echo "  ses              ‚ÄĒ –Ņ–į–ľ—Ź—ā—Ć –Ņ—Ä–ĺ–Ķ–ļ—ā–į"
  echo "  sa \"—ā–Ķ–ļ—Ā—ā\"     ‚ÄĒ –ī–ĺ–Ī–į–≤–ł—ā—Ć –∑–į–ľ–Ķ—ā–ļ—É –≤ –Ņ–į–ľ—Ź—ā—Ć"
    echo ""
    ;;
esac
